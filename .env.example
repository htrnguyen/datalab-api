# ===========================================
# OCR Service Configuration
# ===========================================

# Required: Datalab API keys (comma-separated)
DATALAB_API_KEYS=key1_xxx,key2_xxx

# Datalab API endpoint (default: https://www.datalab.to/api/v1)
DATALAB_BASE_URL=https://www.datalab.to/api/v1

# Optional: Poll interval in seconds (default: 2)
DATALAB_POLL_INTERVAL=2

# Optional: Poll timeout in seconds (default: 120)
DATALAB_POLL_TIMEOUT=120

# Optional: HTTP timeout in seconds (default: 90)
DATALAB_HTTP_TIMEOUT=90

# Optional: Max retries per key (default: 2)
DATALAB_MAX_RETRIES=2

# ===========================================
# Upload Limits
# ===========================================

# Optional: Max upload size in MB (default: 50)
MAX_UPLOAD_SIZE_MB=50

# Optional: Allowed file extensions, comma-separated (default: png,jpg,jpeg,webp,gif,bmp,pdf,tiff,tif)
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp,gif,bmp,pdf,tiff,tif

# ===========================================
# Concurrency Control
# ===========================================

# Optional: Max concurrent requests (default: 5)
# For small team (5-10 users), 5 is recommended
MAX_CONCURRENT_REQUESTS=5

# ===========================================
# Debug Options
# ===========================================

# Optional: Enable debug logging (default: false)
DEBUG_LOG_ENABLED=false

# Optional: Directory for debug logs (default: debug_logs)
DEBUG_DIR=debug_logs

# Optional: Save full API responses for debugging (default: false)
# WARNING: May contain sensitive data, enable only for debugging
DEBUG_SAVE_RESPONSE=false
