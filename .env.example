# Copy to .env and fill keys (supports rotation).
# Comma-separated keys: key_1,key_2,key_3

DATALAB_API_KEYS=your_key_1,your_key_2

# Optional Datalab overrides:
# DATALAB_BASE_URL=https://www.datalab.to/api/v1
# DATALAB_POLL_INTERVAL=2
# DATALAB_POLL_TIMEOUT=20
# DATALAB_REFINE_MAX_DEPTH=6
# DATALAB_BBOX_PADDING=0.02
# DATALAB_HTTP_TIMEOUT=20
# DATALAB_MAX_RETRIES=3

# PaddleOCRv5 text detection (trained model inference).
# Leave PADDLE_TEXT_DET_MODEL_DIR empty to use default PaddleX weights.
PADDLE_TEXT_DET_MODEL_NAME=PP-OCRv5_server_det
PADDLE_TEXT_DET_MODEL_DIR=./inference
PADDLE_TEXT_DET_DEVICE=gpu:0
PADDLE_TEXT_DET_EAGER_LOAD=1
